# ─── Django Core ──────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# USE_SQLITE=true  → uses db.sqlite3 (default for local dev)
# USE_SQLITE=false → uses PostgreSQL (fill vars below)
USE_SQLITE=true

DB_NAME=einvoicing_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ─── RabbitMQ / Celery ────────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# ─── CORS (Next.js frontend) ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── UAE E-Invoicing / ASP Integration ───────────────────────────────────────
ASP_API_BASE_URL=https://mock-asp.example.com/api/v1
ASP_API_KEY=your-asp-api-key-here
ASP_TIMEOUT_SECONDS=30

# ─── Email ────────────────────────────────────────────────────────────────────
# Development: use console backend (prints emails to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production: use SMTP (e.g. Gmail, SendGrid, SES)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=UAE E-Invoicing <noreply@yourdomain.com>
FRONTEND_URL=http://localhost:3000

# ─── AWS S3 (Production — Phase 2) ───────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=me-south-1

# ─── Sentry (Production) ──────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
