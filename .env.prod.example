# ─── Copy this file to .env.prod and fill in real values ──────────────────────
# cp .env.prod.example .env.prod
# NEVER commit .env.prod to git

# ─── Django Core ──────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=api.e-numerak.com

# ─── Database (Docker PostgreSQL) ─────────────────────────────────────────────
DB_NAME=einvoicing_db
DB_USER=einvoicing
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432
DB_SSL_MODE=disable
# PostgreSQL Docker container reads these directly
POSTGRES_DB=einvoicing_db
POSTGRES_USER=einvoicing
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_STRONG_REDIS_PASSWORD@redis:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_THIS_STRONG_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_THIS_STRONG_REDIS_PASSWORD@redis:6379/2

# ─── CORS (allow frontend to call API) ────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://e-numerak.com,https://www.e-numerak.com

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── UAE E-Invoicing / ASP Integration ───────────────────────────────────────
ASP_API_BASE_URL=https://mock-asp.example.com/api/v1
ASP_API_KEY=your-asp-api-key-here
ASP_WEBHOOK_SECRET=CHANGE_THIS_STRONG_WEBHOOK_SECRET
ASP_TIMEOUT_SECONDS=30

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=E-Numerak <noreply@e-numerak.com>

# ─── Frontend URL (used in email links) ──────────────────────────────────────
FRONTEND_URL=https://e-numerak.com

# ─── Flower (Celery Monitor) ──────────────────────────────────────────────────
FLOWER_ADMIN_USER=admin
FLOWER_ADMIN_PASSWORD=CHANGE_THIS_FLOWER_PASSWORD

# ─── PEPPOL / PINT-AE ────────────────────────────────────────────────────────
# Active UAE PINT-AE spec version: 1.0.3 (until 7 Jun 2026) or 1.0.4 (from 8 Jun 2026).
# Flip to 1.0.4 on the cutover date — no code change needed.
PINT_AE_VERSION=1.0.3

# ── AS4 signing credentials ──────────────────────────────────────────────────
# Option A (recommended): single PKCS#12 keystore (.p12) from the PEPPOL portal.
#   Mount /etc/peppol into the backend + celery-worker containers.
PEPPOL_KEYSTORE_PATH=/etc/peppol/ap-test.p12
PEPPOL_KEYSTORE_PASSWORD=change_me_p12_password
# Option B: separate PEM files (cert + UNENCRYPTED key). Leave keystore blank to use these.
# PEPPOL_CERT_PATH=/etc/peppol/cert.pem
# PEPPOL_PRIVATE_KEY_PATH=/etc/peppol/key.pem
# Must be True to sign outbound AS4 (required for PEPPOL Testbed + production).
PEPPOL_SIGNING_ENABLED=True
# Test SML during certification; flip to False only after production PKI is issued.
PEPPOL_USE_TEST_SML=True
# Capture raw inbound AS4 messages to media/as4_debug/ during Testbed certification.
PEPPOL_AS4_DEBUG_CAPTURE=True
