# ── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: NEXT_PUBLIC_API_URL=https://api.e-numerak.com

# ── Site URL (used for sitemap, canonical URLs, OG images) ───────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://e-numerak.com

# ── Google Search Console verification (optional) ───────────────────────────
# Get this from: https://search.google.com/search-console
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here
