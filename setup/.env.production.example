# ─────────────────────────────────────────────────────────────────────────────
# Production .env — copy this file to the project root as .env on the server
#
#   cp setup/.env.production.example .env
#   nano .env
#
# Fill in every value marked with  ← CHANGE
# ─────────────────────────────────────────────────────────────────────────────

# Django
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=                                              # ← CHANGE (generate above)
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=16.170.224.119                             # ← your server IP or domain

# Database (must match setup/2_database.sh values)
USE_SQLITE=false
DB_NAME=einvoicing_db
DB_USER=einvoicing_user
DB_PASSWORD=YourStrongPassword123                        # ← CHANGE (match 2_database.sh)
DB_HOST=localhost
DB_PORT=5432

# CORS — allow the frontend origin
CORS_ALLOWED_ORIGINS=http://16.170.224.119               # ← your server IP or domain

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email — Gmail SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com                     # ← CHANGE
EMAIL_HOST_PASSWORD=your-gmail-app-password              # ← CHANGE (Gmail App Password)
DEFAULT_FROM_EMAIL=UAE E-Invoicing <your-email@gmail.com>
FRONTEND_URL=http://16.170.224.119                       # ← your server IP or domain

# ASP / FTA (mock for now)
ASP_API_BASE_URL=https://mock-asp.example.com/api/v1
ASP_API_KEY=mock-key
ASP_TIMEOUT_SECONDS=30

# Celery / RabbitMQ
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# AWS S3 (optional — for file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=me-south-1

# Sentry (optional — for error tracking)
# SENTRY_DSN=https://xxx@sentry.io/xxx
