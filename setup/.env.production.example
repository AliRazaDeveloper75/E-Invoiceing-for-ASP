# ─────────────────────────────────────────────────────────────────────────────
# Production .env — copy to project root as .env on the EC2 server
#   cp setup/.env.production.example .env && nano .env
# Fill in every value marked with  ← CHANGE
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=                                              # ← CHANGE (generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))")
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=your-ec2-ip,your-ec2-domain.com           # ← CHANGE

# ─── Database: AWS RDS PostgreSQL ─────────────────────────────────────────────
USE_SQLITE=false
DB_NAME=einvoicing_db
DB_USER=einvoicing_user
DB_PASSWORD=                                             # ← CHANGE (RDS password)
DB_HOST=your-rds-endpoint.rds.amazonaws.com             # ← CHANGE (RDS endpoint)
DB_PORT=5432

# ─── CORS — allow Amplify frontend ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.amplifyapp.com    # ← CHANGE (Amplify URL)

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com                     # ← CHANGE
EMAIL_HOST_PASSWORD=your-gmail-app-password              # ← CHANGE
DEFAULT_FROM_EMAIL=UAE E-Invoicing <your-email@gmail.com>
FRONTEND_URL=https://your-app.amplifyapp.com             # ← CHANGE (Amplify URL)

# ─── ASP / FTA ────────────────────────────────────────────────────────────────
ASP_API_BASE_URL=https://mock-asp.example.com/api/v1
ASP_API_KEY=mock-key
ASP_TIMEOUT_SECONDS=30

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# ─── AWS S3 — media file storage ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=                                       # ← CHANGE
AWS_SECRET_ACCESS_KEY=                                   # ← CHANGE
AWS_STORAGE_BUCKET_NAME=einvoicing-media                 # ← CHANGE (your bucket name)
AWS_S3_REGION_NAME=eu-north-1                            # ← CHANGE (your region)

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=
